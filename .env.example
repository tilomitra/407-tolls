# Google Maps Platform API key(s)
# Enable: Maps JavaScript API, Directions API, Places API (New)
#
# You can use a single key for both, or separate keys for tighter restrictions.
# If GOOGLE_DIRECTIONS_API_KEY / GOOGLE_PLACES_API_KEY are unset, the code
# falls back to GOOGLE_MAPS_API_KEY.
GOOGLE_MAPS_API_KEY=
GOOGLE_DIRECTIONS_API_KEY=
GOOGLE_PLACES_API_KEY=
